# ── LINE Bot ───────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret

# ── Firebase ───────────────────────────────────
FIREBASE_PROJECT_ID=lineage-b0156
FIREBASE_CLIENT_EMAIL=your_service_account_email@lineage-b0156.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Google OAuth (管理員登入) ──────────────────
# 到 https://console.cloud.google.com/apis/credentials 建立
# 類型：OAuth 2.0 用戶端 ID > 網頁應用程式
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── 管理員帳號 (逗號分隔) ─────────────────────
# 只有以下 Gmail 帳號登入後才有管理員權限
ADMIN_EMAILS=admin1@gmail.com,admin2@gmail.com

# ── ChromaDB 向量資料庫 ───────────────────────
CHROMA_SERVER_URL=http://localhost:8000
CHROMA_SERVER_TOKEN=your_chromadb_token_here
